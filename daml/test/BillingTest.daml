module BillingTest where

import Daml.Script
import DA.Date
import DA.Time
import DA.Assert
import DA.Foldable (sum)
import DA.Either

-- Core modules of the application being tested
import Subscription
import Invoice
import Billing

-- A simplified fungible token for testing purposes.
-- In a real-world scenario, this would likely be an imported standard token,
-- e.g., from a library compliant with a token standard like CIP-0056.
template MockToken
  with
    owner: Party
    amount: Decimal
  where
    signatory owner

    key owner : Party
    maintainer key

    choice Split: (ContractId MockToken, ContractId MockToken)
      with
        splitAmount: Decimal
      controller owner
      do
        assertMsg "Split amount must be positive" $ splitAmount > 0.0
        assertMsg "Split amount cannot exceed total amount" $ splitAmount <= amount
        let remainingAmount = amount - splitAmount
        remainingCid <- create this with amount = remainingAmount
        splitCid <- create this with amount = splitAmount
        return (remainingCid, splitCid)

    choice Merge: ContractId MockToken
      with
        otherCids: [ContractId MockToken]
      controller owner
      do
        tokens <- mapA fetch otherCids
        assertMsg "Cannot merge with self" $ self `notElem` otherCids
        assertMsg "All tokens must have the same owner to be merged" $ all (\t -> t.owner == owner) tokens
        archiveMany otherCids
        create this with amount = amount + sum (map (\t -> t.amount) tokens)

-- Helper to calculate the total balance of MockToken for a given party.
getTotalBalance : Party -> Script Decimal
getTotalBalance party = do
  tokens <- query @MockToken party
  return $ sum (map (\(_, t) -> t.amount) tokens)

-- Helper to setup a consistent test environment with standard parties and a subscription plan.
setupTestEnv = do
  provider <- allocatePartyWithHint "Provider" (PartyIdHint "provider")
  subscriber <- allocatePartyWithHint "Subscriber" (PartyIdHint "subscriber")
  billingEngine <- allocatePartyWithHint "BillingEngine" (PartyIdHint "billingengine")

  let today = date 2024 Feb 15
  let plan = Plan with
        provider
        planId = "premium-monthly-v1"
        description = "Premium Monthly Subscription"
        rate = 29.99
        billingInterval = Months 1
        gracePeriodDays = 14

  planCid <- submit provider do createCmd plan
  roleCid <- submit provider do createCmd (BillingEngineRole provider billingEngine)

  return (provider, subscriber, billingEngine, today, plan, planCid, roleCid)

-- Main test suite for billing logic.
billingTests : Script ()
billingTests = do
  -- Test 1: Happy path where the subscriber has sufficient funds for payment.
  test "Successful billing cycle debits subscriber and credits provider" do
    (provider, subscriber, billingEngine, today, plan, planCid, roleCid) <- setupTestEnv

    -- Setup: Give subscriber enough funds and create an active subscription.
    _ <- submit subscriber do createCmd (MockToken subscriber 100.0)
    subscriptionCid <- submit subscriber do
      exerciseCmd planCid Subscribe with subscriber, startDate = today

    -- Action: The billing engine processes the billing cycle for the subscription.
    (newSubscriptionCid, result) <- submit billingEngine do
      exerciseCmd subscriptionCid ProcessBillingCycle with asOf = today

    -- Assertions:
    -- 1. The result of the choice should be a 'Right' containing a paid Invoice.
    let paidInvoiceCid = fromRight' "Expected a successful payment (Right)" result
    paidInvoice <- fetch paidInvoiceCid
    paidInvoice.provider === provider
    paidInvoice.subscriber === subscriber
    paidInvoice.amount === plan.rate

    -- 2. The subscription should be updated to 'Active' with a new billing date.
    newSubscription <- fetch newSubscriptionCid
    newSubscription.status === Active
    newSubscription.nextBillingDate === addMonths 1 today

    -- 3. Token balances should reflect the payment.
    (getTotalBalance subscriber) >>= \bal -> assertEq (100.0 - plan.rate) bal
    (getTotalBalance provider) >>= \bal -> assertEq plan.rate bal

  -- Test 2: Scenario where the subscriber has insufficient funds, triggering a grace period.
  test "Failed payment due to insufficient funds enters grace period" do
    (provider, subscriber, billingEngine, today, plan, planCid, roleCid) <- setupTestEnv

    -- Setup: Give subscriber INSUFFICIENT funds and create an active subscription.
    _ <- submit subscriber do createCmd (MockToken subscriber 10.0)
    subscriptionCid <- submit subscriber do
      exerciseCmd planCid Subscribe with subscriber, startDate = today

    -- Action: Billing engine attempts to process the cycle, which is expected to fail.
    (newSubscriptionCid, result) <- submit billingEngine do
      exerciseCmd subscriptionCid ProcessBillingCycle with asOf = today

    -- Assertions:
    -- 1. The result should be a 'Left' containing a FailedInvoice.
    let failedInvoiceCid = fromLeft' "Expected a failed payment (Left)" result
    failedInvoice <- fetch failedInvoiceCid
    failedInvoice.provider === provider
    failedInvoice.subscriber === subscriber
    failedInvoice.amount === plan.rate

    -- 2. The subscription should transition to the 'InGracePeriod' status.
    newSubscription <- fetch newSubscriptionCid
    newSubscription.status === InGracePeriod
    newSubscription.gracePeriodEnds === Some (addDays plan.gracePeriodDays today)

    -- 3. Token balances should remain unchanged as the payment failed.
    (getTotalBalance subscriber) >>= \bal -> assertEq 10.0 bal
    (getTotalBalance provider) >>= \bal -> assertEq 0.0 bal

  -- Test 3: Scenario where the grace period expires without payment, leading to service suspension.
  test "Grace period expiry suspends service" do
    (provider, subscriber, billingEngine, today, plan, planCid, roleCid) <- setupTestEnv

    -- Setup: Create a subscription that is already in its grace period.
    let graceEndsDate = addDays plan.gracePeriodDays today
    let subInGracePeriod = Subscription with
          provider
          subscriber
          planCid
          status = InGracePeriod
          startDate = addMonths (-1) today
          nextBillingDate = today
          gracePeriodEnds = Some graceEndsDate
    subInGraceCid <- submit provider do createCmd subInGracePeriod

    -- Action:
    -- 1. Advance ledger time past the grace period end date.
    let expiryCheckDate = addDays 1 graceEndsDate
    passTime (time (toDateUTC expiryCheckDate) 0 0 0)

    -- 2. The billing engine enforces the expiry.
    suspendedSubCid <- submit billingEngine do
      exerciseCmd subInGraceCid EnforceGracePeriodExpiry with asOf = expiryCheckDate

    -- Assertions:
    -- 1. The subscription status should now be 'Suspended'.
    suspendedSub <- fetch suspendedSubCid
    suspendedSub.status === Suspended
    suspendedSub.gracePeriodEnds === None

    -- 2. Verify no active or grace period subscriptions remain for the subscriber.
    query @Subscription subscriber >>= \subs -> do
      let activeOrGraceSubs = filter (\(_, s) -> s.status == Active || s.status == InGracePeriod) subs
      length activeOrGraceSubs === 0