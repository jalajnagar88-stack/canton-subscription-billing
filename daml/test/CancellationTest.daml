module Subscription.Test.CancellationTest where

import Daml.Script
import DA.Date as Date
import DA.Time as Time
import DA.Assert
import DA.Optional (fromSome)

-- Internal Imports
import Subscription.Plan (Plan(..))
import Subscription.Model (Subscription(..), SubscriptionStatus(..))
import Subscription.Cancellation (CancellationRequest(..), Cancelled(..))

-- Mock time for consistent testing, start of a year.
t0: Time = time (Date.date 2024 1 1) 0 0 0

-- | Sets up common parties and a standard plan for testing.
setup : Script (Party, Party, Party, ContractId Plan)
setup = do
  provider <- allocatePartyWithHint "Provider" (PartyIdHint "provider")
  subscriber <- allocatePartyWithHint "Subscriber" (PartyIdHint "subscriber")
  billingEngine <- allocatePartyWithHint "BillingEngine" (PartyIdHint "billingengine")

  let planData = Plan
        with
          provider = provider
          billingEngine = billingEngine
          planId = "pro-monthly"
          description = "Pro Monthly Plan"
          price = 30.0
          billingIntervalDays = 30
          gracePeriodDays = 5
          suspensionPeriodDays = 10
          observers = []

  planCid <- submit provider do
    createCmd planData

  return (provider, subscriber, billingEngine, planCid)

-- | Main entry point for all cancellation-related tests.
cancellationTests : Script ()
cancellationTests = script do
  test_subscriber_can_cancel_active_subscription
  test_prorated_refund_on_cancellation
  test_cancellation_during_grace_period
  test_cancelled_user_can_resubscribe

-- | Verifies that a subscriber can successfully cancel an active subscription.
test_subscriber_can_cancel_active_subscription : Script ()
test_subscriber_can_cancel_active_subscription = script do
  p "START: test_subscriber_can_cancel_active_subscription"
  (provider, subscriber, _, planCid) <- setup

  -- Arrange: Create an active subscription
  let subscriptionStartDate = Date.date 2024 2 1
  setTime (time subscriptionStartDate 0 0 0)

  (subscriptionCid, _) <- submit subscriber do
    exerciseCmd planCid Plan_Subscribe with subscriber

  -- Act: Subscriber requests cancellation
  cancellationRequestCid <- submit subscriber do
    exerciseCmd subscriptionCid Subscription_RequestCancellation with reason = "No longer need the service."

  -- Provider accepts the cancellation
  (cancelledCid, refundAmount) <- submit provider do
    exerciseCmd cancellationRequestCid CancellationRequest_Accept

  -- Assert
  -- The original subscription and request should be archived
  assertFalse "Subscription contract should be archived after cancellation" =<< queryContractId subscriber subscriptionCid
  assertFalse "CancellationRequest should be archived after acceptance" =<< queryContractId provider cancellationRequestCid
  
  -- A Cancelled contract should exist with correct details
  Some cancelledContract <- queryContractId provider cancelledCid
  cancelledContract.provider === provider
  cancelledContract.subscriber === subscriber
  cancelledContract.planId === "pro-monthly"
  
  -- Since cancellation happened on the start day of the period, refund should be the full amount.
  refundAmount === 30.0
  cancelledContract.refundAmount === 30.0
  p "SUCCESS: test_subscriber_can_cancel_active_subscription"
  return ()

-- | Verifies that the prorated refund is calculated correctly based on the cancellation date.
test_prorated_refund_on_cancellation : Script ()
test_prorated_refund_on_cancellation = script do
  p "START: test_prorated_refund_on_cancellation"
  (provider, subscriber, _, planCid) <- setup
  plan <- fromSome "Plan contract not found" <$> queryContractId provider planCid

  -- Arrange: Create an active subscription
  let periodStartDate = Date.date 2024 3 1
  setTime (time periodStartDate 0 0 0)

  (subscriptionCid, _) <- submit subscriber do
    exerciseCmd planCid Plan_Subscribe with subscriber

  -- Act: Advance time by 10 days and then cancel
  let cancellationDate = Date.addDays periodStartDate 10
  setTime (time cancellationDate 0 0 0)

  cancellationRequestCid <- submit subscriber do
    exerciseCmd subscriptionCid Subscription_RequestCancellation with reason = "Found a better alternative."
  
  (_, refundAmount) <- submit provider do
    exerciseCmd cancellationRequestCid CancellationRequest_Accept

  -- Assert: Check if refund is correctly prorated
  -- Total days in period = 30
  -- Days used = 10 (from Mar 1 to Mar 10)
  -- Days remaining = 20
  -- Expected refund = (price / total days) * remaining days = (30.0 / 30) * 20 = 20.0
  let daysUsed = 10
  let expectedRefund = (plan.price / intToDecimal plan.billingIntervalDays) * intToDecimal (plan.billingIntervalDays - daysUsed)
  assertEq refundAmount expectedRefund
  
  -- Verify the created Cancelled contract has the correct refund amount
  [(_, cancelledContract)] <- queryContracts @Cancelled provider
  assertEq cancelledContract.subscriber subscriber
  assertEq cancelledContract.planId plan.planId
  assertEq cancelledContract.refundAmount expectedRefund
  p "SUCCESS: test_prorated_refund_on_cancellation"
  return ()

-- | Verifies that cancelling during a grace period (after a failed payment) results in no refund.
test_cancellation_during_grace_period : Script ()
test_cancellation_during_grace_period = script do
  p "START: test_cancellation_during_grace_period"
  (provider, subscriber, billingEngine, planCid) <- setup

  -- Arrange: Create an active subscription
  let periodStartDate = Date.date 2024 4 1
  setTime (time periodStartDate 0 0 0)
  (subscriptionCid, _) <- submit subscriber do
    exerciseCmd planCid Plan_Subscribe with subscriber

  -- Simulate a failed payment to transition subscription to GracePeriod
  subscriptionInGracePeriodCid <- submit billingEngine do
    exerciseCmd subscriptionCid Subscription_RecordPaymentFailure

  Some subInGrace <- queryContractId subscriber subscriptionInGracePeriodCid
  subInGrace.status === GracePeriod

  -- Act: Subscriber cancels while in grace period
  cancellationRequestCid <- submit subscriber do
    exerciseCmd subscriptionInGracePeriodCid Subscription_RequestCancellation with reason = "Service unreliable."

  (cancelledCid, refundAmount) <- submit provider do
    exerciseCmd cancellationRequestCid CancellationRequest_Accept

  -- Assert: No refund should be issued for a period that wasn't paid for.
  assertEq refundAmount 0.0
  
  Some cancelledContract <- queryContractId provider cancelledCid
  assertEq cancelledContract.refundAmount 0.0
  assertEq cancelledContract.subscriber subscriber

  -- The grace period subscription should be archived.
  assertFalse "Subscription in grace period should be archived" =<< queryContractId subscriber subscriptionInGracePeriodCid
  p "SUCCESS: test_cancellation_during_grace_period"
  return ()

-- | Verifies that a user who has previously cancelled their subscription can re-subscribe.
test_cancelled_user_can_resubscribe : Script ()
test_cancelled_user_can_resubscribe = script do
  p "START: test_cancelled_user_can_resubscribe"
  (provider, subscriber, _, planCid) <- setup

  -- Arrange: A user subscribes and then cancels their subscription
  setTime (time (Date.date 2024 5 1) 0 0 0)
  (subscriptionCid, _) <- submit subscriber do
    exerciseCmd planCid Plan_Subscribe with subscriber
  
  cancellationRequestCid <- submit subscriber do
    exerciseCmd subscriptionCid Subscription_RequestCancellation with reason = "Initial test."
  
  (cancelledCid, _) <- submit provider do
    exerciseCmd cancellationRequestCid CancellationRequest_Accept
  
  -- Assert that a cancelled contract exists for the user
  Some _ <- queryContractId provider cancelledCid

  -- Act: The same user re-subscribes to the same plan at a later date
  let resubscribeDate = Date.date 2024 6 1
  setTime (time resubscribeDate 0 0 0)
  
  (newSubscriptionCid, _) <- submit subscriber do
    exerciseCmd planCid Plan_Subscribe with subscriber

  -- Assert: A new subscription is created successfully
  assert (newSubscriptionCid /= subscriptionCid) "A new subscription contract ID should be created"
  
  Some newSubContract <- queryContractId subscriber newSubscriptionCid
  newSubContract.subscriber === subscriber
  newSubContract.provider === provider
  newSubContract.status === Active
  newSubContract.currentPeriodStart === resubscribeDate
  
  -- The old Cancelled contract should still exist for record keeping
  Some oldCancelledContract <- queryContractId provider cancelledCid
  assertEq oldCancelledContract.subscriber subscriber
  p "SUCCESS: test_cancelled_user_can_resubscribe"
  return ()